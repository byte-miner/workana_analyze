# OpenAI API key — used for AI Helper (help.workana.com) and market insights
OPENAI_API_KEY=sk-proj-...

# Workana session cookie value (PHPSESSID)
WORKANA_SESSION=your_session_id_here

# SOCKS5 proxy (host:port:user:pass) — used when direct connection fails
WORKANA_PROXY=socks5://host:port:user:pass

# Network mode: auto (default), always (force proxy), never (force direct/VPN)
WORKANA_PROXY_MODE=auto

# Scraper settings
SCRAPE_MAX_PAGES=50
SCRAPE_INTERVAL_MS=300000
